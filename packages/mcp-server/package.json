{
  "name": "@context-condenser/mcp-server",
  "version": "0.1.0",
  "description": "MCP server — bridges Claude/Gemini to the LVM engine",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lvm-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --minify --shims",
    "dev": "tsup src/index.ts --format esm --watch --shims",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@context-condenser/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
